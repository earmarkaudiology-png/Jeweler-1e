    function handleHaggle(msg, args) {
        var buyer = resolveBuyer(msg, args);
        var quote = _.find(allQuotes(), function (q) { return q.id === args.quote; });
        var target, roll, success, resultText;
        if (!buyer || !quote || quote.buyerId !== buyer.id) {
            send(box('Haggle Price', 'Quote not found for this buyer.' + backMenuButton(buyer ? buyer.id : '')));
            return;
        }
        if (quote.haggleDone) {
            send(box('Haggle Price',
                line('Item', esc(quote.itemName)) +
                '<div>Haggling is already finished for this quote.</div>' +
                backMenuButton(buyer.id)
            ));
            return;
        }
        target = Math.max(0, Math.min(95, 10 + (Number(quote.reactionBonus) || 0)));
        roll = randomInteger(100);
        success = roll <= target;
        quote.haggleAttempts = (quote.haggleAttempts || 0) + 1;
        if (quote.kind === 'sale') {
            if (success) {
                quote.currentOfferGp = Math.min(quote.baseValueGp, roundGp((quote.currentOfferGp || quote.offerGp) * 1.05));
                quote.haggleDone = true;
                resultText = '<span style="color:#8fe38f;font-weight:bold;">Success - dealer improves the offer by 5%.</span>';
            } else {
                quote.haggleFailures = (quote.haggleFailures || 0) + 1;
                quote.lastHaggleComment = randomJewelerSaleComment();
                if (quote.haggleFailures >= 2) {
                    quote.currentOfferGp = roundGp((quote.currentOfferGp || quote.offerGp) * 0.90);
                    quote.haggleDone = true;
                    resultText = '<span style="color:#ff7b7b;font-weight:bold;">Second failure - dealer lowers the offer by 10% and ends haggling.</span>';
                } else {
                    resultText = '<span style="color:#ffb36b;font-weight:bold;">Failure - no change yet. One more haggle attempt remains.</span>';
                }
            }
            send(box('Haggle Result',
                line('Item', esc(quote.itemName)) +
                line('Haggle target', esc(String(target)) + '%') +
                line('Die roll', esc(String(roll))) +
                line('Result', resultText) +
                ((!success && quote.lastHaggleComment) ? line('Dealer says', esc(quote.lastHaggleComment)) : '') +
                line('Current offer', formatCoinsFromGp(quote.currentOfferGp || quote.offerGp)) +
                '<div style="margin-top:8px;">' +
                    menuBtn('Sell Item', '!jeweler-accept --pc|' + buyer.id + ' --quote|' + quote.id, CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 100) +
                    (!quote.haggleDone ? menuBtn('Haggle Price', '!jeweler-haggle --pc|' + buyer.id + ' --quote|' + quote.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 100) : '') +
                    (!success ? menuBtn('Deny Quote', '!jeweler-deny --pc|' + buyer.id + ' --quote|' + quote.id, CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder, 100) : '') +
                '</div>' + backMenuButton(buyer.id)
            ));
            return;
        }
        if (success) {
            quote.currentServiceChargeGp = Math.max(1, roundGp((quote.currentServiceChargeGp || quote.serviceChargeGp) * 0.95));
            quote.haggleDone = true;
            resultText = '<span style="color:#8fe38f;font-weight:bold;">Success - jeweler reduces the service charge by 5%.</span>';
        } else {
            quote.haggleFailures = (quote.haggleFailures || 0) + 1;
            quote.lastHaggleComment = randomHaggleFailComment();
            if (quote.haggleFailures >= 2) {
                quote.currentServiceChargeGp = Math.max(1, roundGp((quote.currentServiceChargeGp || quote.serviceChargeGp) * 1.10));
                quote.haggleDone = true;
                resultText = '<span style="color:#ff7b7b;font-weight:bold;">Second failure - jeweler raises the service charge by 10% and ends haggling.</span>';
            } else {
                resultText = '<span style="color:#ffb36b;font-weight:bold;">Failure - no change yet. One more haggle attempt remains.</span>';
            }
        }
        setQuotePayments(quote);
        send(box('Haggle Result',
            line('Item', esc(quote.itemName)) +
            line('Haggle target', esc(String(target)) + '%') +
            line('Die roll', esc(String(roll))) +
            line('Result', resultText) +
            ((!success && quote.lastHaggleComment) ? line('Jeweler says', esc(quote.lastHaggleComment)) : '') +
            line('Current total charge', formatCoinsFromGp(quote.currentServiceChargeGp || quote.serviceChargeGp)) +
            line('Paid now', formatCoinsFromGp(quote.depositGp || 0)) +
            (quote.balanceGp ? line('Balance on pickup', formatCoinsFromGp(quote.balanceGp || 0)) : '') +
            '<div style="margin-top:8px;">' +
                menuBtn('Accept Quote', '!jeweler-accept --pc|' + buyer.id + ' --quote|' + quote.id, CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 110) +
                (!quote.haggleDone ? menuBtn('Haggle Price', '!jeweler-haggle --pc|' + buyer.id + ' --quote|' + quote.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 100) : '') +
                (!success ? menuBtn('Deny Quote', '!jeweler-deny --pc|' + buyer.id + ' --quote|' + quote.id, CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder, 100) : '') +
            '</div>' + backMenuButton(buyer.id)
        ));
    }


    function handleApplyDays(msg, args) {
        var buyer = resolveBuyer(msg, args);
        var days = Math.max(1, Number(args.days) || 1);
        var jobs, completed = [];
        if (!buyer) {
            send(box('Jeweler', 'Select a buyer token first.' + backMenuButton('')));
            return;
        }
        jobs = _.filter(allJobs(), function (j) { return j.buyerId === buyer.id && j.status === 'working'; });
        if (!jobs.length) {
            send(box('Jeweler', 'No active jobs for ' + esc(getBuyerName(buyer)) + '.' + backMenuButton(buyer.id)));
            return;
        }
        _.each(jobs, function (job) {
            job.daysRemaining = Math.max(0, job.daysRemaining - days);
            if (job.daysRemaining === 0 && job.status === 'working') {
                completed.push(resolveCompletedJob(job));
            }
        });

        send(box('Jeweler Time Applied',
            line('Buyer', esc(getBuyerName(buyer))) +
            line('Days applied', esc(String(days))) +
            line('Active jobs checked', esc(String(jobs.length))) +
            (completed.length ? line('Jobs completed', esc(String(completed.length))) : line('Jobs completed', '0')) +
            backMenuButton(buyer.id)
        ));

        _.each(completed, function (entry) {
            if (entry.publicHtml) send(entry.publicHtml);
            if (entry.gmHtml) sendGM(entry.gmHtml);
        });
    }

