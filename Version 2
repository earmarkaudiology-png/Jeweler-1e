    }

    function handleStoreHaggle(msg, args) {
        var buyer = resolveBuyer(msg, args);
        var price = roundGp(Number(args.price) || 0);
        var attempt = Number(args.attempt) || 0;
        var target, roll, success, resultText, comment = '';
        if (!buyer) {
            send(box('Haggle Price', 'Select a buyer token first.' + backMenuButton('')));
            return;
        }
        target = Math.max(0, Math.min(95, 10 + (getReactionBonus(buyer) || 0)));
        roll = randomInteger(100);
        success = roll <= target;
        if (success) {
            price = roundGp(price * 0.95);
            resultText = '<span style="color:#8fe38f;font-weight:bold;">Success - dealer reduces the asking price by 5%.</span>';
        } else if (attempt >= 1) {
            price = roundGp(price * 1.10);
            comment = randomHaggleFailComment();
            resultText = '<span style="color:#ff7b7b;font-weight:bold;">Second failure - dealer raises the asking price by 10% and ends haggling.</span>';
        } else {
            comment = randomHaggleFailComment();
            resultText = '<span style="color:#ffb36b;font-weight:bold;">Failure - no change yet. One more haggle attempt remains.</span>';
        }
        send(box('Haggle Result',
            line('Item', esc(args.itemname || 'Item')) +
            line('Haggle target', esc(String(target)) + '%') +
            line('Die roll', esc(String(roll))) +
            line('Result', resultText) +
            (comment ? line('Jeweler says', esc(comment)) : '') +
            line('Current asking price', formatCoinsFromGp(price)) +
            '<div style="margin-top:8px;">' +
                menuBtn('Purchase', '!jeweler-store-buy --pc|' + buyer.id + ' --itemname|' + (args.itemname || 'Item') + ' --price|' + price + ' --kind|' + (args.kind || 'item'), CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 90) +
                ((!success && attempt < 1) ? menuBtn('Haggle Price', '!jeweler-store-haggle --pc|' + buyer.id + ' --itemname|' + (args.itemname || 'Item') + ' --price|' + price + ' --kind|' + (args.kind || 'item') + ' --attempt|1', CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 110) : '') +
            '</div>' + backMenuButton(buyer.id)
        ));
    }


    function handleReport(msg, args) {
        var buyer = resolveBuyer(msg, args);
        var body = '';
        if (!buyer) {
            send(box('Jeweler Report', 'Select a buyer token first.' + backMenuButton('')));
            return;
        }
        body += line('Buyer', esc(getBuyerName(buyer)));
        body += line('Available jewelers', esc(String(allJewelers().length)));
        var quotes = getQuotesForBuyer(buyer.id);
        var jobs = _.filter(allJobs(), function (j) { return j.buyerId === buyer.id && j.status !== 'done'; });
        if (quotes.length) {
            body += '<div style="margin-top:6px;"><b>Open Quotes</b></div>' +
                _.map(quotes, function (q) {
                    return '<div style="margin-left:8px;">' + esc(q.itemName) + ' — ' + esc(q.jewelerName) + ' — ' + (q.kind === 'sale' ? 'offer ' + formatCoinsFromGp(q.currentOfferGp || q.offerGp) : formatCoinsFromGp(q.currentServiceChargeGp || q.serviceChargeGp)) + '</div>';
                }).join('');
        } else {
            body += '<div style="margin-top:6px;"><b>Open Quotes</b>: none</div>';
        }
        if (jobs.length) {
            body += '<div style="margin-top:6px;"><b>Jobs</b></div>' +
                _.map(jobs, function (j) {
                    var extra = '';
                    if (j.status === 'ready') {
                        extra = ' ' + menuBtn('Finish/Pick Up', '!jeweler-pickup --pc|' + buyer.id + ' --job|' + j.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 120);
                    } else if (j.status === 'working') {
                        extra = ' ' + menuBtn('Finish Now', '!jeweler-finish-now --pc|' + buyer.id + ' --job|' + j.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 100);
                    }
                    return '<div style="margin-left:8px;margin-bottom:6px;">' + esc(j.itemName) + ' — ' + esc(j.jewelerName) +
                        ' — ' + esc(j.status) + ' — ' + esc(String(j.daysRemaining)) + '/' + esc(String(j.daysTotal)) + ' day(s) remaining' +
                        ' — total ' + formatCoinsFromGp(j.serviceChargeGp || 0) +
                        ' — down ' + formatCoinsFromGp(j.depositGp || 0) +
                        ' — balance ' + formatCoinsFromGp(j.balanceGp || 0) + extra + '</div>';
                }).join('');
        } else {
            body += '<div style="margin-top:6px;"><b>Jobs</b>: none</div>';
        }

        if (playerIsGMFor(msg)) {
            var jewelers = _.sortBy(allJewelers(), function (j) { return (j.name || '').toLowerCase(); });
            body += '<div style="margin-top:6px;"><b>Available Jewelers</b></div>';
            body += jewelers.length ? _.map(jewelers, function (j) {
                return '<div style="margin-left:8px;">' + esc(jewelerLabel(j)) + '</div>';
            }).join('') : '<div style="margin-left:8px;">none</div>';
        }

        send(box('Jeweler Report', body + backMenuButton(buyer.id)));
    }

    function handleRemoveList(msg, args) {
        var buyer = resolveBuyer(msg, args);
        var mine;
        if (!buyer) {
            send(box('Jeweler', 'Select an employer token first.' + backMenuButton('')));
            return;
        }
        mine = _.filter(allJewelers(), function (j) { return j.ownerId === buyer.id; });
        if (!mine.length) {
            send(box('Jeweler', 'No jeweler-gemcutters are kept by ' + esc(getBuyerName(buyer)) + '.' + backMenuButton(buyer.id)));
            return;
        }
        send(box('Remove Jeweler',
            _.map(mine, function (j) {
                return '<div style="margin-bottom:4px;">' + esc(jewelerLabel(j)) + ' ' +
                    menuBtn('Remove', '!jeweler-remove --pc|' + buyer.id + ' --jeweler|' + j.id, CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder, 80) +
                    '</div>';
            }).join('') + backMenuButton(buyer.id)
        ));
    }

    function handleRemove(msg, args) {
        var buyer = resolveBuyer(msg, args);
        state[STATE].jewelers = _.reject(allJewelers(), function (j) { return j.id === args.jeweler; });
        state[STATE].quotes = _.reject(allQuotes(), function (q) { return q.jewelerId === args.jeweler; });
        state[STATE].jobs = _.reject(allJobs(), function (j) { return j.jewelerId === args.jeweler && j.status !== 'done'; });
        send(box('Jeweler', 'Jeweler removed.' + backMenuButton(buyer ? buyer.id : '')));
    }

    function handleRemoveAll(msg, args) {
        var buyer = resolveBuyer(msg, args);
        if (!buyer) {
            send(box('Jeweler', 'Select an employer token first.' + backMenuButton('')));
            return;
        }
        if (normalizeText(args.confirm) !== 'yes') {
            send(box('Jeweler', 'Removal cancelled.' + backMenuButton(buyer.id)));
            return;
        }
        var jewelerIds = _.pluck(_.filter(allJewelers(), function (j) { return j.ownerId === buyer.id; }), 'id');
        state[STATE].jewelers = _.reject(allJewelers(), function (j) { return j.ownerId === buyer.id; });
        state[STATE].quotes = _.reject(allQuotes(), function (q) { return q.buyerId === buyer.id || _.contains(jewelerIds, q.jewelerId); });
        state[STATE].jobs = _.reject(allJobs(), function (j) { return j.buyerId === buyer.id || (_.contains(jewelerIds, j.jewelerId) && j.status !== 'done'); });
        send(box('Jeweler', 'All jeweler data for ' + esc(getBuyerName(buyer)) + ' removed.' + backMenuButton(buyer.id)));
    }

    function handleReset(msg, args) {
        if (!playerIsGMFor(msg)) {
            send(box('Jeweler', 'GM only.'));
            return;
        }
        if (normalizeText(args.confirm) !== 'yes') {
            send(box('Jeweler', 'Reset cancelled.'));
            return;
        }
        state[STATE] = {
            version: VERSION,
            nextJewelerId: 1,
            nextQuoteId: 1,
            nextJobId: 1,
            jewelers: [],
            quotes: [],
            jobs: []
        };
        send(box('Jeweler', 'Campaign data reset.'));
    }

    function handleInput(msg) {
        if (msg.type !== 'api') return;
        if (!msg.content || msg.content.indexOf('!jeweler') !== 0) return;
        whisperTarget = String(msg.who || '').replace(/ \(GM\)$/, '');
        var command = msg.content.split(/\s+/)[0];
        var args = parseArgs(msg.content);
        switch (command) {
            case '!jeweler-menu': handleMenu(msg, args); break;
            case '!jeweler-add': handleAddJeweler(msg, args); break;
            case '!jeweler-select-service': handleSelectService(msg, args); break;
            case '!jeweler-start-quote': handleStartQuote(msg, args); break;
            case '!jeweler-quote': handleQuote(msg, args); break;
            case '!jeweler-open-quotes': handleOpenQuotes(msg, args); break;
            case '!jeweler-accept': handleAccept(msg, args); break;
            case '!jeweler-deny': handleDeny(msg, args); break;
            case '!jeweler-haggle': handleHaggle(msg, args); break;
            case '!jeweler-apply-days': handleApplyDays(msg, args); break;
            case '!jeweler-finish-now': handleFinishNow(msg, args); break;
            case '!jeweler-ready': handleReady(msg, args); break;
            case '!jeweler-pickup': handlePickup(msg, args); break;
            case '!jeweler-store-list': handleStoreList(msg, args); break;
            case '!jeweler-store-buy': handleStoreBuy(msg, args); break;
            case '!jeweler-store-haggle': handleStoreHaggle(msg, args); break;
            case '!jeweler-report': handleReport(msg, args); break;
            case '!jeweler-remove-list': handleRemoveList(msg, args); break;
            case '!jeweler-remove': handleRemove(msg, args); break;
            case '!jeweler-remove-all': handleRemoveAll(msg, args); break;
            case '!jeweler-reset': handleReset(msg, args); break;
            default: handleMenu(msg, args); break;
        }
    }

    function checkInstall() {
        stateInit();
        log(SCRIPT + ' v' + VERSION + ' ready.');
    }

    function registerEventHandlers() {
        on('chat:message', handleInput);
    }

    return {
        CheckInstall: checkInstall,
        RegisterEventHandlers: registerEventHandlers
    };
}());

on('ready', function () {
    'use strict';
    Jeweler.CheckInstall();
    Jeweler.RegisterEventHandlers();
});
