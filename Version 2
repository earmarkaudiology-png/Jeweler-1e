            buttons.join(' ') + '</div>';
    }

    function backMenuButton(pcId) {
        return '<div style="margin-top:8px;">' +
            menuBtn('Main Menu', '!jeweler-menu' + (pcId ? ' --pc|' + pcId : ''), CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 92) +
            '</div>';
    }

    function selectedCharacter(msg) {
        if (!msg.selected || !msg.selected.length) return null;
        var tok = getObj('graphic', msg.selected[0]._id);
        if (!tok) return null;
        var charId = tok.get('represents');
        if (!charId) return null;
        return getObj('character', charId);
    }

    function resolveBuyer(msg, args) {
        var ch = selectedCharacter(msg);
        if (ch) return ch;
        if (args.pc) return getObj('character', args.pc);
        return null;
    }

    function getBuyerName(buyer) {
        return buyer ? (buyer.get('name') || 'Buyer') : 'Buyer';
    }

    function getReactionBonus(buyer) {
        if (!buyer) return 0;
        return Number(getAttr(buyer.id, CONFIG.reactionAttr, 0)) || 0;
    }

    function getAttrObj(charId, name) {
        var found = findObjs({ type: 'attribute', characterid: charId, name: name })[0];
        if (!found) {
            found = createObj('attribute', { characterid: charId, name: name, current: 0 });
        }
        return found;
    }

    function getAttr(charId, name, defVal) {
        var obj = findObjs({ type: 'attribute', characterid: charId, name: name })[0];
        if (!obj) return defVal;
        var v = obj.get('current');
        return v === '' || v === undefined || v === null ? defVal : v;
    }

    function setAttr(charId, name, val) {
        getAttrObj(charId, name).set('current', val);
    }

    function coinSummary(charId) {
        return {
            gp: Number(getAttr(charId, CONFIG.coinAttrs.gp, 0)) || 0,
            sp: Number(getAttr(charId, CONFIG.coinAttrs.sp, 0)) || 0,
            cp: Number(getAttr(charId, CONFIG.coinAttrs.cp, 0)) || 0
        };
    }

    function cpTotal(charId) {
        var c = coinSummary(charId);
        return (c.gp * 100) + (c.sp * 10) + c.cp;
    }

    function formatCoinsFromCp(totalCp) {
        totalCp = Math.max(0, Math.floor(totalCp || 0));
        var gp = Math.floor(totalCp / 100);
        var rem = totalCp % 100;
        var sp = Math.floor(rem / 10);
        var cp = rem % 10;
        return gp + ' gp, ' + sp + ' sp, ' + cp + ' cp';
    }

    function gpToCp(gp) {
        return Math.max(0, Math.round((Number(gp) || 0) * 100));
    }

    function cpToGp(cp) {
        return Math.round((Number(cp) || 0)) / 100;
    }

    function formatCoinsFromGp(gp) {
        return formatCoinsFromCp(gpToCp(gp));
    }

    function jewelryHasGems(desc) {
        desc = normalizeText(desc || '');
        return desc.indexOf('gems') !== -1;
    }

    function randRangeInt(min, max) {
        min = Number(min) || 0;
        max = Number(max) || 0;
        if (max < min) {
            var t = min; min = max; max = t;
        }
        return randomInteger(max - min + 1) + min - 1;
    }

    function gemValueStepsGp() {
        return [0.01, 0.05, 0.1, 1, 5, 10, 50, 100, 500, 1000, 5000, 10000, 25000, 50000, 100000, 250000, 500000, 1000000];
    }

    function nearestGemStepIndex(baseGp) {
        var steps = gemValueStepsGp();
        var best = 0, bestDiff = Infinity;
        _.each(steps, function (v, i) {
            var diff = Math.abs(v - baseGp);
            if (diff < bestDiff) {
                bestDiff = diff;
                best = i;
            }
        });
        return best;
    }

    function rollGemTrueValue(baseGp) {
        var steps = gemValueStepsGp();
        var startIdx = nearestGemStepIndex(baseGp);
        var currentIdx = startIdx;
        var upMoves = 0, downMoves = 0;
        var log = [];

        function nextHigherAllowed(maxRoll) {
            var r;
            do { r = randomInteger(10); } while (r > maxRoll);
            return r;
        }
        function nextLowerAllowed() {
            var r;
            do { r = randomInteger(10); } while (r < 2);
            return r;
        }
        function applyRoll(roll) {
            if (roll === 1) {
                if (upMoves < 7 && currentIdx < steps.length - 1) {
                    currentIdx += 1;
                    upMoves += 1;
                }
                var rr = nextHigherAllowed(8);
                log.push('1 -> next higher base, reroll=' + rr);
                applyRoll(rr);
            } else if (roll === 2) {
                // double the exact base entered
                var doubled = Math.max(0.01, Number(baseGp) || 0) * 2;
                log.push('2 -> double entered base');
                currentIdx = null;
                log.push('double');
                return doubled;
            } else if (roll === 3) {
                var d6 = randomInteger(6);
                var pct = d6 * 10;
                log.push('3 -> +' + pct + '%');
                return steps[currentIdx] * (1 + pct / 100);
            } else if (roll >= 4 && roll <= 8) {
                log.push(String(roll) + ' -> unchanged');
                return steps[currentIdx];
            } else if (roll === 9) {
                var d4 = randomInteger(4);
                var pct2 = d4 * 10;
                log.push('9 -> -' + pct2 + '%');
                return steps[currentIdx] * (1 - pct2 / 100);
            } else { // 10 / 0
                if (downMoves < 5 && currentIdx > 0) {
                    currentIdx -= 1;
                    downMoves += 1;
                }
                var rr2 = nextLowerAllowed();
                log.push('0 -> next lower base, reroll=' + rr2);
                applyRoll(rr2);
            }
        }

        var first = randomInteger(10);
        log.push('d10=' + first);
        var val = applyRoll(first);
        if (typeof val !== 'number' || !isFinite(val)) {
            val = steps[currentIdx];
        }
        return {
            baseInputGp: baseGp,
            finalGp: Math.max(0.01, Math.round(val * 100) / 100),
            log: log.join('; ')
        };
    }

    function rollJewelryBase() {
        var d100 = randomInteger(100);
        var data;
        if (d100 <= 10) data = { min: 100, max: 1000, desc: 'Ivory or wrought silver' };
        else if (d100 <= 20) data = { min: 200, max: 1200, desc: 'Wrought silver and gold' };
        else if (d100 <= 40) data = { min: 300, max: 1800, desc: 'Wrought gold' };
        else if (d100 <= 50) data = { min: 500, max: 3000, desc: 'Jade, coral or wrought platinum' };
        else if (d100 <= 70) data = { min: 1000, max: 6000, desc: 'Silver with gems' };
        else if (d100 <= 90) data = { min: 2000, max: 8000, desc: 'Gold with gems' };
        else data = { min: 2000, max: 12000, desc: 'Platinum with gems' };
        data.roll = d100;
        data.baseGp = randRangeInt(data.min, data.max);
        return data;
    }

    function maybeExceptionalJewelry(data) {
        var workmanshipRoll = randomInteger(10);
        var log = ['d10 workmanship=' + workmanshipRoll];
        if (workmanshipRoll !== 1) {
            return {
                baseGp: data.baseGp,
                desc: data.desc,
                log: log.join('; ')
            };
        }
        // on 1, either highest in class or next higher class
        var up = randomInteger(2) === 2;
        log.push(up ? 'exceptional -> next class' : 'exceptional -> highest in class');
        if (!up) {
            return { baseGp: data.max, desc: data.desc, log: log.join('; ') };
        }
        // promote by re-rolling in next higher class if possible
        var promotedRoll = Math.min(100, data.roll + 20);
        var promoted;
        if (promotedRoll <= 10) promoted = { min: 100, max: 1000, desc: 'Ivory or wrought silver', roll: promotedRoll };
        else if (promotedRoll <= 20) promoted = { min: 200, max: 1200, desc: 'Wrought silver and gold', roll: promotedRoll };
        else if (promotedRoll <= 40) promoted = { min: 300, max: 1800, desc: 'Wrought gold', roll: promotedRoll };
        else if (promotedRoll <= 50) promoted = { min: 500, max: 3000, desc: 'Jade, coral or wrought platinum', roll: promotedRoll };
        else if (promotedRoll <= 70) promoted = { min: 1000, max: 6000, desc: 'Silver with gems', roll: promotedRoll };
        else if (promotedRoll <= 90) promoted = { min: 2000, max: 8000, desc: 'Gold with gems', roll: promotedRoll };
        else promoted = { min: 2000, max: 12000, desc: 'Platinum with gems', roll: promotedRoll };
        promoted.baseGp = randRangeInt(promoted.min, promoted.max);
        var inner = maybeExceptionalJewelry(promoted);
        return { baseGp: inner.baseGp, desc: inner.desc, log: log.concat(inner.log).join('; ') };
    }

    function rollJewelryTrueValue() {
        var base = rollJewelryBase();
        var resolved = maybeExceptionalJewelry(base);
        var finalGp = resolved.baseGp;
        var log = ['d100 class=' + base.roll, 'base=' + base.baseGp + ' gp', resolved.log];
        if (jewelryHasGems(resolved.desc)) {
            var d8 = randomInteger(8);
            log.push('d8 gem exceptional=' + d8);
            if (d8 === 1) {
                var bonus = 5000;
                finalGp += bonus;
                while (finalGp < 640000 && randomInteger(6) === 1) {
                    bonus *= 2;
                    finalGp += bonus;
                    log.push('d6 chain 1 -> bonus now ' + bonus);
                }
            }
        }
        return {
            baseGp: resolved.baseGp,
            finalGp: finalGp,
            desc: resolved.desc,
            log: log.join('; ')
        };
    }

    function rollCommodityValue(kind, args) {
        var log = [];
        if (kind === 'fur') {
            var prices = {
                beaver: { pelt: 2, trimming: 20, cape: 200, coat: 400 },
                ermine: { pelt: 4, trimming: 120, cape: 3600, coat: 7200 },
                fox: { pelt: 3, trimming: 30, cape: 300, coat: 600 },
                marten: { pelt: 4, trimming: 40, cape: 400, coat: 800 },
                mink: { pelt: 3, trimming: 90, cape: 2700, coat: 5400 },
                muskrat: { pelt: 1, trimming: 10, cape: 100, coat: 200 },
                sable: { pelt: 5, trimming: 150, cape: 4500, coat: 9000 },
                seal: { pelt: 5, trimming: 25, cape: 125, coat: 250 }
            };
            var type = normalizeText(args.furtype || 'beaver');
            var form = normalizeText(args.furform || 'pelt');
            if (form === 'capeorjacket') form = 'cape';
            var qty = Math.max(1, Number(args.quantity) || 1);
            var base = ((prices[type] || prices.beaver)[form] || prices.beaver.pelt) * qty;
            var d10 = randomInteger(10);
            var modMap = {1:-10,2:-20,3:-30,4:-40,5:0,6:0,7:0,8:0,9:10,10:20};
            var pct = modMap[d10];
            log.push('d10=' + d10 + ' => ' + pct + '%');
            return { baseGp: base, finalGp: Math.round(base * (1 + pct/100) * 100) / 100, desc: 'Fur appraisal', log: log.join('; ') };
        }
        var qty2 = Math.max(1, Number(args.quantity) || 1);
        var ranges = {
            brocade: [1,20,'square yard'],
            incense: [5,30,'stick'],
            ivory: [3,6,'pound'],
            pepper: [1,1,'ounce'],
            perfume: [1,6,'dram'],
            silk: [1,3,'square yard'],
            spice: [0.1,0.4,'scruple'],
            unguent: [10,60,'gill']
        };
        var key = normalizeText(args.commodity || 'ivory');
        var r = ranges[key] || ranges.ivory;
        var total = 0;
        for (var i = 0; i < qty2; i++) {
            if (r[0] === r[1]) total += r[0];
            else total += (Math.round((Math.random() * (r[1]-r[0]) + r[0]) * 100) / 100);
        }
        return { baseGp: 0, finalGp: Math.round(total*100)/100, desc: 'Commodity appraisal', log: qty2 + ' ' + r[2] + '(s)' };
    }

    function estimateJewelryAppraisal(args) {
        var hidden = rollJewelryTrueValue();
        var claimedBase = Number(args.basevalue || 0) || 0;
        return {
            baseValueGp: claimedBase || hidden.baseGp,
            trueValueGp: hidden.finalGp,
            hiddenDesc: hidden.desc,
            hiddenLog: hidden.log
        };
    }

    function estimateGemAppraisal(args) {
        var base = Number(args.basevalue || 0) || 0;
        var hidden = rollGemTrueValue(base);
        return {
            baseValueGp: base,
            trueValueGp: hidden.finalGp,
            hiddenDesc: 'Gem',
            hiddenLog: hidden.log
        };
    }

    function estimateCommodityAppraisal(args) {
        var sub = normalizeText(args.subkind || 'commodity');
        var hidden = rollCommodityValue(sub, args);
        return {
            baseValueGp: hidden.baseGp || 0,
            trueValueGp: hidden.finalGp,
            hiddenDesc: hidden.desc,
            hiddenLog: hidden.log
        };
    }

    function deductCoins(charId, gpCost) {
        var costCp = Math.max(0, Math.ceil((Number(gpCost) || 0) * 100));
        var total = cpTotal(charId);
        if (total < costCp) return { ok: false, needCp: costCp, haveCp: total };
        total -= costCp;
        var gp = Math.floor(total / 100);
        var rem = total % 100;
        var sp = Math.floor(rem / 10);
        var cp = rem % 10;
        setAttr(charId, CONFIG.coinAttrs.gp, gp);
        setAttr(charId, CONFIG.coinAttrs.sp, sp);
        setAttr(charId, CONFIG.coinAttrs.cp, cp);
        return { ok: true, spentCp: costCp, remainingCp: total };
    }


    function addCoins(charId, gpAmount) {
        var addCp = Math.max(0, Math.round((Number(gpAmount) || 0) * 100));
        var total = cpTotal(charId) + addCp;
        var gp = Math.floor(total / 100);
        var rem = total % 100;
        var sp = Math.floor(rem / 10);
        var cp = rem % 10;
        setAttr(charId, CONFIG.coinAttrs.gp, gp);
        setAttr(charId, CONFIG.coinAttrs.sp, sp);
        setAttr(charId, CONFIG.coinAttrs.cp, cp);
        return { ok: true, addedCp: addCp, totalCp: total };
    }

    function appraisalFeeGp(buyer) {
        var base = randomIntegerInclusive(1, 5);
        var rb = getReactionBonus(buyer);
        var fee = Math.round(base * (1 - (rb / 100)) * 100) / 100;
        return Math.max(1, Math.min(5, fee));
    }

    function playerIsGMFor(msg) {
        return playerIsGM(msg.playerid);
    }

    function allJewelers() {
        return state[STATE].jewelers;
    }

    function allQuotes() {
        return state[STATE].quotes;
    }

    function allJobs() {
        return state[STATE].jobs;
    }

    function getJewelerById(id) {
        return _.find(allJewelers(), function (j) { return j.id === id; });
    }

    function getQuotesForBuyer(buyerId) {
        return _.filter(allQuotes(), function (q) { return q.buyerId === buyerId; });
    }

    function getJobsForBuyer(buyerId) {
        return _.filter(allJobs(), function (j) { return j.buyerId === buyerId && j.status !== 'done'; });
    }

    function getOpenJobsForJeweler(jewelerId) {
        return _.filter(allJobs(), function (j) { return j.jewelerId === jewelerId && j.status !== 'done'; });
    }

    function makeJewelerId() {
        return 'J' + (state[STATE].nextJewelerId++);
    }
    function makeQuoteId() {
        return 'Q' + (state[STATE].nextQuoteId++);
    }
    function makeJobId() {
        return 'JOB' + (state[STATE].nextJobId++);
    }

    function jewelerSkillTier(roll) {
        roll = clamp(roll, 1, 100);
        if (roll <= 20) return { code: 'fair', label: 'Fair', primaryPct: 10, primaryLikely: 90, fallbackPct: 0 };
        if (roll <= 50) return { code: 'good', label: 'Good', primaryPct: 20, primaryLikely: 50, fallbackPct: 10 };
        if (roll <= 75) return { code: 'superior', label: 'Superior', primaryPct: 30, primaryLikely: 60, fallbackPct: 10 };
        if (roll <= 90) return { code: 'excellent', label: 'Excellent', primaryPct: 40, primaryLikely: 70, fallbackPct: 10 };
        return { code: 'masterful', label: 'Masterful', primaryPct: 40, primaryLikely: 60, fallbackPct: 20 };
    }

    function gemcutterSkillTier(roll) {
        roll = clamp(roll, 1, 100);
        if (roll <= 30) return { code: 'shaky', label: 'Shaky', die: 12, improve: [1], ruin: [10,11,12] };
        if (roll <= 60) return { code: 'fair', label: 'Fair', die: 12, improve: [1,2], ruin: [12] };
        if (roll <= 90) return { code: 'good', label: 'Good', die: 12, improve: [1,2,3], ruin: [12] };
        return { code: 'superb', label: 'Superb', die: 20, improve: [1,2,3,4,5], ruin: [20] };
    }

    function jewelerResultPct(jeweler) {
        var tier = jewelerSkillTier(jeweler.jewelerRollAdjusted);
        var roll = randomInteger(100);
        var pct = (roll <= tier.primaryLikely) ? tier.primaryPct : tier.fallbackPct;
        return { pct: pct, tier: tier, roll: roll };
    }

    function gemcutOutcome(jeweler) {
        var tier = gemcutterSkillTier(jeweler.gemcutterRollAdjusted);
        var dieRoll = randomInteger(tier.die);
        var improve = _.contains(tier.improve, dieRoll);
        var ruin = _.contains(tier.ruin, dieRoll);
        return { improve: improve, ruin: ruin, tier: tier, die: tier.die, roll: dieRoll };
    }

    function monthlyWageForJeweler(j) {
        var race = CONFIG.raceData[normalizeText(j.race)] || CONFIG.raceData.human;
        return CONFIG.baseMonthlyWageGp * race.wageMult;
    }

    function serviceChargeForDays(j, days) {
        days = Math.max(1, Number(days) || 1);
        return Math.max(1, Math.ceil((monthlyWageForJeweler(j) * days) / 30));
    }

    function addJeweler(owner, name, race) {
        var raceKey = normalizeText(race);
        if (!CONFIG.raceData[raceKey]) raceKey = 'human';
        var raceInfo = CONFIG.raceData[raceKey];
        var jewelerBase = randomInteger(100);
        var gemBase = randomInteger(100);
        var jewelerAdj = clamp(jewelerBase + raceInfo.jewelerBonus, 1, 100);
        var gemAdj = clamp(gemBase + raceInfo.gemcutterBonus, 1, 100);
        var jeweler = {
            id: makeJewelerId(),
            name: name || randomName(),
            race: raceKey,
            ownerId: owner ? owner.id : '',
            ownerName: owner ? owner.get('name') : '',
            jewelerRollBase: jewelerBase,
            jewelerRollAdjusted: jewelerAdj,
            gemcutterRollBase: gemBase,
            gemcutterRollAdjusted: gemAdj,
            created: Date.now()
        };
        allJewelers().push(jeweler);
        return jeweler;
    }

    function jewelerLabel(j) {
        var raceInfo = CONFIG.raceData[normalizeText(j.race)] || CONFIG.raceData.human;
        return j.name + ' (' + raceInfo.label + ')' + (j.ownerName ? ' — kept by ' + j.ownerName : '');
    }

    function availableJewelerButtons(pcId, kind) {
        var jewelers = _.sortBy(allJewelers(), function (j) { return (j.name || '').toLowerCase(); });
        if (!jewelers.length) return '<div>No jeweler-gemcutters are available.</div>';
        return _.map(jewelers, function (j) {
            return menuBtn(jewelerLabel(j), '!jeweler-start-quote --pc|' + pcId + ' --kind|' + kind + ' --jeweler|' + j.id, CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 210);
        }).join(' ');
    }

    function jewelryKindLabel(kind) {
        switch (kind) {
            case 'ring': return 'Simple Ring';
            case 'bracelet_sculpt': return 'Bracelet with Sculpting';
            case 'bracelet_stones': return 'Bracelet with Stones Set';
            case 'crown': return 'Crown';
            case 'custom': return 'Custom Jewelry Work';
            default: return kind;
        }
    }

    function roundGp(n) {
        return Math.round((Number(n) || 0) * 100) / 100;
    }

    function setQuotePayments(quote) {
        if (quote.kind === 'sale') {
            quote.depositGp = 0;
            quote.balanceGp = 0;
            return;
        }
        if (quote.paymentMode === 'upfront') {
            quote.depositGp = roundGp(quote.currentServiceChargeGp || quote.serviceChargeGp || 0);
            quote.balanceGp = 0;
        } else {
            var total = roundGp(quote.currentServiceChargeGp || quote.serviceChargeGp || 0);
            quote.depositGp = roundGp(total / 2);
            quote.balanceGp = roundGp(total - quote.depositGp);
        }
    }

    function saleOfferGp(appraisedGp, buyer) {
        var discount = randomIntegerInclusive(15, 20) - (getReactionBonus(buyer) || 0);
        discount = Math.max(0, Math.min(95, discount));
        return {
            offerGp: roundGp(appraisedGp * (1 - discount / 100)),
            discountPct: discount
        };
    }

    function jewelerAskPriceGp(trueValueGp, buyer) {
        var markup = randomIntegerInclusive(10, 35) - Math.floor((getReactionBonus(buyer) || 0) / 2);
        markup = Math.max(0, markup);
        return roundGp(trueValueGp * (1 + markup / 100));
    }

    function generateStoreInventory(size, buyer) {
        var cfg = {
            small: { gemsMin: 2, gemsMax: 5, jewelryMin: 0, jewelryMax: 2, gemBuckets: ['ornamental','ornamental','semi','semi','fancy'] },
            medium: { gemsMin: 4, gemsMax: 8, jewelryMin: 1, jewelryMax: 4, gemBuckets: ['ornamental','semi','semi','fancy','fancy','gem'] },
            large: { gemsMin: 7, gemsMax: 14, jewelryMin: 3, jewelryMax: 7, gemBuckets: ['semi','semi','fancy','fancy','gem','gem'] }
        }[normalizeText(size || 'small')] || { gemsMin: 2, gemsMax: 5, jewelryMin: 0, jewelryMax: 2, gemBuckets: ['ornamental','semi','fancy'] };
        var out = { gems: [], jewelry: [] };
        var gemCount = randomIntegerInclusive(cfg.gemsMin, cfg.gemsMax);
        var jewelryCount = randomIntegerInclusive(cfg.jewelryMin, cfg.jewelryMax);
        var i, bucket, entry, rolled, item;
        for (i = 0; i < gemCount; i++) {
            bucket = randomPick(cfg.gemBuckets);
            entry = randomPick(GEM_CATALOG[bucket]);
            rolled = rollGemTrueValue(entry[1]);
            item = {
                name: entry[0],
                category: bucket,
                baseGp: entry[1],
                trueValueGp: rolled.finalGp,
                askGp: jewelerAskPriceGp(rolled.finalGp, buyer)
            };
            out.gems.push(item);
        }
        for (i = 0; i < jewelryCount; i++) {
            rolled = rollJewelryTrueValue();
            item = {
                name: randomPick(JEWELRY_FORMS),
                desc: rolled.desc,
                baseGp: rolled.baseGp,
                trueValueGp: rolled.finalGp,
                askGp: jewelerAskPriceGp(rolled.finalGp, buyer)
            };
            out.jewelry.push(item);
        }
        return out;
    }

    function createQuote(buyer, jeweler, kind, args) {
        var baseValue = Number(args.basevalue || 0) || 0;
        var days = Number(args.days || 0) || 0;
        var serviceDays = days;
        var detailText = '';
        var itemType = '';
        var appraisalData = null;
        var paymentMode = 'halfdown';
        var baseService = 0;
        var offerInfo = null;
        if (kind === 'gemappraisal' || kind === 'appraisal') {
            serviceDays = CONFIG.workDays.appraisal;
            itemType = 'gem';
            detailText = 'Gem appraisal';
            appraisalData = estimateGemAppraisal(args);
            baseValue = appraisalData.baseValueGp;
            paymentMode = 'upfront';
            baseService = appraisalFeeGp(buyer);
        } else if (kind === 'jewelryappraisal') {
            serviceDays = CONFIG.workDays.appraisal;
            itemType = 'jewelry';
            detailText = 'Jewelry appraisal';
            appraisalData = estimateJewelryAppraisal(args);
            baseValue = appraisalData.baseValueGp;
            paymentMode = 'upfront';
            baseService = appraisalFeeGp(buyer);
        } else if (kind === 'commodityappraisal') {
            serviceDays = CONFIG.workDays.appraisal;
            itemType = 'commodity';
            detailText = normalizeText(args.subkind || 'commodity') === 'fur' ? 'Fur appraisal' : 'Rare commodity appraisal';
            appraisalData = estimateCommodityAppraisal(args);
            baseValue = appraisalData.baseValueGp;
            paymentMode = 'upfront';
            baseService = appraisalFeeGp(buyer);
        } else if (kind === 'sale') {
            serviceDays = 0;
            itemType = normalizeText(args.itemtype || 'item');
            detailText = 'Dealer purchase offer';
            baseValue = Number(args.appraisedvalue || 0) || 0;
            offerInfo = saleOfferGp(baseValue, buyer);
            baseService = 0;
            paymentMode = 'sale';
        } else if (kind === 'gemcut') {
            serviceDays = CONFIG.workDays.gemcut;
            itemType = 'gem';
            detailText = 'Gem cutting attempt';
            baseService = serviceChargeForDays(jeweler, serviceDays);
        } else {
            itemType = 'jewelry';
            serviceDays = CONFIG.workDays[args.jobtype] || CONFIG.workDays.ring;
            detailText = jewelryKindLabel(args.jobtype || 'ring');
            baseService = serviceChargeForDays(jeweler, serviceDays);
        }

        var quote = {
            id: makeQuoteId(),
            buyerId: buyer.id,
            buyerName: buyer.get('name') || '',
            jewelerId: jeweler.id,
            jewelerName: jeweler.name,
            kind: kind,
            itemName: args.itemname || 'Unnamed item',
            itemType: itemType,
            jobtype: args.jobtype || '',
            baseValueGp: baseValue,
            trueValueGp: appraisalData ? appraisalData.trueValueGp : (Number(args.truevalue || 0) || 0),
            appraisalHiddenDesc: appraisalData ? appraisalData.hiddenDesc : '',
            appraisalHiddenLog: appraisalData ? appraisalData.hiddenLog : '',
            days: serviceDays,
            serviceChargeGp: baseService,
            currentServiceChargeGp: baseService,
            baseServiceChargeGp: baseService,
            depositGp: 0,
            balanceGp: 0,
            paymentMode: paymentMode,
            reactionBonus: getReactionBonus(buyer),
            haggleAttempts: 0,
            haggleFailures: 0,
            haggleDone: false,
            lastHaggleComment: '',
            detailText: detailText,
            created: Date.now(),
            offerGp: offerInfo ? offerInfo.offerGp : 0,
            currentOfferGp: offerInfo ? offerInfo.offerGp : 0,
            baseOfferGp: offerInfo ? offerInfo.offerGp : 0,
            discountPct: offerInfo ? offerInfo.discountPct : 0,
            sourceJobId: args.sourcejob || ''
        };
        setQuotePayments(quote);
        allQuotes().push(quote);
        return quote;
    }

    function removeQuote(id) {
        state[STATE].quotes = _.reject(allQuotes(), function (q) { return q.id === id; });
    }

    function getSaleQuoteForSourceJob(jobId) {
        return _.find(allQuotes(), function (q) { return q.kind === 'sale' && q.sourceJobId === jobId; });
    }

    function ensureDealerOfferQuoteForJob(job) {
        var buyer, jeweler;
        if (!job || !(job.kind === 'appraisal' || job.kind === 'gemappraisal' || job.kind === 'jewelryappraisal' || job.kind === 'commodityappraisal')) return null;
        if (getSaleQuoteForSourceJob(job.id)) return getSaleQuoteForSourceJob(job.id);
        buyer = getObj('character', job.buyerId);
        jeweler = getJewelerById(job.jewelerId);
        if (!buyer || !jeweler) return null;
        return createQuote(buyer, jeweler, 'sale', {
            itemname: job.itemName,
            itemtype: job.itemType,
            appraisedvalue: String(job.trueValueGp || 0),
            sourcejob: job.id
        });
    }

    function acceptQuote(buyer, quote) {
        var upfrontGp = Number(quote.depositGp) || 0;
        var spend = deductCoins(buyer.id, upfrontGp);
        if (!spend.ok) {
            return { ok: false, spend: spend };
        }
        var job = {
            id: makeJobId(),
            buyerId: quote.buyerId,
            buyerName: quote.buyerName,
            jewelerId: quote.jewelerId,
            jewelerName: quote.jewelerName,
            kind: quote.kind,
            itemName: quote.itemName,
            itemType: quote.itemType,
            jobtype: quote.jobtype,
            baseValueGp: quote.baseValueGp,
            trueValueGp: quote.trueValueGp,
            appraisalHiddenDesc: quote.appraisalHiddenDesc || '',
            appraisalHiddenLog: quote.appraisalHiddenLog || '',
            daysTotal: quote.days,
            daysRemaining: quote.days,
            serviceChargeGp: quote.currentServiceChargeGp || quote.serviceChargeGp,
            depositGp: quote.depositGp || 0,
            balanceGp: quote.balanceGp || 0,
            status: 'working',
            created: Date.now()
        };
        allJobs().push(job);
        removeQuote(quote.id);
        return { ok: true, job: job, spend: spend };
    }

    function acceptSaleQuote(buyer, quote) {
        var paid = addCoins(buyer.id, quote.currentOfferGp || quote.offerGp || 0);
        removeQuote(quote.id);
        return { ok: true, paid: paid, offerGp: quote.currentOfferGp || quote.offerGp || 0 };
    }

    function resolveCompletedJob(job) {
        var jeweler = getJewelerById(job.jewelerId);
        var publicBody = line('Jeweler', esc(job.jewelerName)) + line('Item', esc(job.itemName));
        var gmBody = line('Buyer', esc(job.buyerName)) + line('Jeweler', esc(job.jewelerName));
        if (jeweler) {
            gmBody += line('Jeweler skill raw', String(jeweler.jewelerRollAdjusted)) + line('Gemcutter skill raw', String(jeweler.gemcutterRollAdjusted));
        }

        if (job.kind === 'appraisal' || job.kind === 'gemappraisal') {
            publicBody += line('Base value', formatCoinsFromGp(job.baseValueGp)) + line('True value', formatCoinsFromGp(job.trueValueGp));
            gmBody += line('Gem appraisal', esc(job.appraisalHiddenLog || ''));
        } else if (job.kind === 'jewelryappraisal') {
            publicBody += line('Base value', formatCoinsFromGp(job.baseValueGp)) + line('True value', formatCoinsFromGp(job.trueValueGp));
            gmBody += line('Jewelry class', esc(job.appraisalHiddenDesc || '')) + line('Jewelry appraisal', esc(job.appraisalHiddenLog || ''));
        } else if (job.kind === 'commodityappraisal') {
            if (job.baseValueGp) publicBody += line('Base value', formatCoinsFromGp(job.baseValueGp));
            publicBody += line('True value', formatCoinsFromGp(job.trueValueGp));
            gmBody += line('Commodity appraisal', esc(job.appraisalHiddenLog || ''));
        } else if (job.kind === 'jewelry') {
            var jres = jewelerResultPct(jeweler);
            var finalValue = Math.round(job.baseValueGp * (1 + (jres.pct / 100)) * 100) / 100;
            publicBody += line('Work', esc(jewelryKindLabel(job.jobtype || 'custom'))) +
                line('Original value', formatCoinsFromGp(job.baseValueGp)) +
                line('Improvement', '+' + esc(String(jres.pct)) + '%') +
                line('Final value', formatCoinsFromGp(finalValue));
            gmBody += line('Jeweler tier', esc(jres.tier.label)) +
                line('Chance roll', String(jres.roll) + ' vs ' + String(jres.tier.primaryLikely) + '%') +
                line('Increase applied', '+' + String(jres.pct) + '%');
        } else if (job.kind === 'gemcut') {
            var gout = gemcutOutcome(jeweler);
            if (gout.ruin) {
                publicBody += line('Result', 'The stone was ruined in the cutting.');
            } else if (gout.improve) {
                var gres = jewelerResultPct(jeweler);
                var gfinal = Math.round(job.baseValueGp * (1 + (gres.pct / 100)) * 100) / 100;
                publicBody += line('Original value', formatCoinsFromGp(job.baseValueGp)) +
                    line('Result', 'The stone was improved.') +
                    line('Improvement', '+' + esc(String(gres.pct)) + '%') +
                    line('Final value', formatCoinsFromGp(gfinal));
                gmBody += line('Gemcut roll', 'd' + gout.die + ' = ' + gout.roll) +
                    line('Gemcut tier', esc(gout.tier.label)) +
                    line('Jeweler value roll', '+' + String(gres.pct) + '%');
            } else {
                publicBody += line('Original value', formatCoinsFromGp(job.baseValueGp)) +
                    line('Result', 'The stone was cut, but its value did not improve.');
                gmBody += line('Gemcut roll', 'd' + gout.die + ' = ' + gout.roll) +
                    line('Gemcut tier', esc(gout.tier.label));
            }
        }

        job.status = (job.balanceGp && job.balanceGp > 0) ? 'ready' : 'done';
        job.daysRemaining = 0;
        var btns = '';
        if (job.balanceGp && job.balanceGp > 0) {
            btns += menuBtn('Finish/Pick Up', '!jeweler-pickup --pc|' + job.buyerId + ' --job|' + job.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 120);
        }
        if (job.kind === 'appraisal' || job.kind === 'gemappraisal' || job.kind === 'jewelryappraisal' || job.kind === 'commodityappraisal') {
            ensureDealerOfferQuoteForJob(job);
            publicBody += line('Dealer offer', 'Added to Open Quotes.');
            btns += menuBtn('Open Quotes', '!jeweler-open-quotes --pc|' + job.buyerId, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110);
        }
        btns += backMenuButton(job.buyerId);
        publicBody += line('Paid now', formatCoinsFromGp(job.depositGp || 0)) + (job.balanceGp ? line('Balance due', formatCoinsFromGp(job.balanceGp)) : '') + '<div style="margin-top:8px;">' + btns + '</div>';
        return {
            publicHtml: box('Jeweler Job Complete', publicBody),
            gmHtml: box('Jeweler GM Detail', gmBody)
        };
    }

