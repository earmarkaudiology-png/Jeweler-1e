    function box(title, body) {
        return '<div style="background:' + CONFIG.colors.panelBg + ';border:1px solid ' + CONFIG.colors.panelBorder +
            ';padding:8px;color:' + CONFIG.colors.text + ';max-width:520px;">' +
            '<div style="font-weight:bold;font-size:18px;margin-bottom:6px;">' + esc(title) + '</div>' +
