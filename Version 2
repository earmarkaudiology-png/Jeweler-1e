    function parseArgs(content) {
        var args = {};
        (content.match(/--[^\s|]+(?:\|(?:[^\s]| (?!--))*)?/g) || []).forEach(function (part) {
            var idx = part.indexOf('|');
            var key = part.substring(2, idx > -1 ? idx : undefined);
            var val = idx > -1 ? part.substring(idx + 1) : 'yes';
            args[key] = val;
        });
        return args;
    }

    var whisperTarget = '';

    function send(msg) {
        if (whisperTarget) {
            sendChat(SCRIPT, '/w "' + whisperTarget + '" ' + msg);
            return;
        }
        sendChat(SCRIPT, '/direct ' + msg);
    }

    function sendGM(msg) {
        sendChat(SCRIPT, '/w gm ' + msg);
